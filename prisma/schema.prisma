generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  /// bcrypt hash; null for OAuth-only accounts
  passwordHash     String?
  accounts         Account[]
  careerRoadmap    CareerRoadmap?
  eventRsvps       EventRsvp[]
  peerHelpRequests PeerHelpRequest[]
  profile          Profile?
  sessions         Session[]
}

model CareerRoadmap {
  id            String   @id @default(cuid())
  userId        String   @unique
  /// Up to 2 career slugs, e.g. ["it_support","data_analyst"]
  careers       String[]
  ageRange      String
  workStatus    String
  expLevel      String
  hasDegree     Boolean
  /// Stored path under /uploads/career-resumes or external URL
  resumeRef     String?
  timelineLabel String
  goalStatement String
  /// JSON: { sections: { careerId, label, steps: RoadmapStep[] }[] }
  planJson      String
  /// JSON: Record<stepId, boolean>
  progressJson  String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  bio                   String?
  school                String?
  major                 String?
  gradYear              String?
  location              String?
  linkedin              String?
  github                String?
  interests             String[] @default([])
  languages             String[] @default([])
  userType              String   @default("student")
  onboardingComplete    Boolean  @default(false)
  education             String?
  firstGen              Boolean?
  internationalOrDaca   Boolean?
  careerPath            String?
  receivingScholarships Boolean?
  scholarshipDetails    String?
  seekingScholarships   Boolean?
  experienceLevel       String?
  portfolio             String?
  communityPrefs        String[] @default([])
  learningStyle         String?
  preferredContentLang  String?
  challenges            String?
  yearlyGoal            String?
  /// Non-student path
  ageRange              String?
  /// Root onboarding split: tailored student vs career-transition experience
  audienceSegment       String?
  careerIntentText      String?
  hasCollegeDegree      Boolean?
  nonStudentSituation   String?
  primaryBarrier        String?
  /// Shared across both flows (6-month focus for AI / roadmap)
  sixMonthGoal          String?
  /// Student path
  studentFieldInterest  String?
  studentPrimaryGoal    String?
  targetCareerSlugs     String[] @default([])
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Student-to-student help requests (mock interviews, resume review, career advice).
model PeerHelpRequest {
  id        String   @id @default(cuid())
  userId    String
  /// career_advice | mock_interview | resume_review
  type      String
  context   String
  /// open | closed
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([type])
  @@index([createdAt])
}


model Event {
  id        String      @id @default(cuid())
  title     String
  date      DateTime
  endDate   DateTime?
  type      String
  link      String?
  location  String?
  attendees Int         @default(0)
  rsvps     EventRsvp[]
}

model EventRsvp {
  id      String @id @default(cuid())
  userId  String
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  user    User   @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
}

model Scholarship {
  id               String    @id @default(cuid())
  name             String
  organization     String
  description      String?
  amount           String?
  deadline         DateTime?
  gpaRequirement   Float?
  levelRequirement String[]
  majors           String[]
  tags             String[]
  applyUrl         String
  createdAt        DateTime  @default(now())
}

