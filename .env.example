# Copy to `.env.local`. Never commit secrets.
# Email/password sign-in works without any OAuth variables below.

AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Supabase → Connect. Use pooler if Direct (db.*.supabase.co) gives P1001 on your network.
#
# Transaction pooler (port 6543) — app runtime. Append: ?pgbouncer=true&sslmode=require
# DATABASE_URL="postgresql://postgres.<ref>:PASSWORD@aws-?.<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Session pooler (port 5432) — Prisma migrate. Same host as transaction, different port.
# DIRECT_URL="postgresql://postgres.<ref>:PASSWORD@aws-?.<region>.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Copy host + user from the dashboard; do not guess aws-0 vs aws-1 or region.

DATABASE_URL=
DIRECT_URL=

# GitHub (easiest): github.com → Settings → Developer settings → OAuth Apps → New
# Callback: http://localhost:3000/api/auth/callback/github  (use :3001 if dev server says so)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
